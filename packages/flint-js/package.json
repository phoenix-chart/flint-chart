{
  "name": "flint-chart",
  "version": "0.1.0",
  "description": "Semantic-level visualization library that compiles data + semantic types into chart specs for Vega-Lite, ECharts, Chart.js, and GoFish.",
  "keywords": [
    "visualization",
    "charts",
    "vega-lite",
    "echarts",
    "chart.js",
    "gofish",
    "semantic-types",
    "llm",
    "agent",
    "data-visualization"
  ],
  "license": "MIT",
  "author": "Microsoft Corporation",
  "homepage": "https://github.com/microsoft/flint-chart#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/microsoft/flint-chart.git",
    "directory": "packages/flint-js"
  },
  "bugs": {
    "url": "https://github.com/microsoft/flint-chart/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./vegalite": {
      "types": "./dist/vegalite/index.d.ts",
      "import": "./dist/vegalite/index.js",
      "require": "./dist/vegalite/index.cjs"
    },
    "./echarts": {
      "types": "./dist/echarts/index.d.ts",
      "import": "./dist/echarts/index.js",
      "require": "./dist/echarts/index.cjs"
    },
    "./chartjs": {
      "types": "./dist/chartjs/index.d.ts",
      "import": "./dist/chartjs/index.js",
      "require": "./dist/chartjs/index.cjs"
    },
    "./gofish": {
      "types": "./dist/gofish/index.d.ts",
      "import": "./dist/gofish/index.js",
      "require": "./dist/gofish/index.cjs"
    },
    "./test-data": {
      "types": "./dist/test-data/index.d.ts",
      "import": "./dist/test-data/index.js",
      "require": "./dist/test-data/index.cjs"
    },
    "./gallery": {
      "types": "./dist/gallery/index.d.ts",
      "import": "./dist/gallery/index.js",
      "require": "./dist/gallery/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\"",
    "clean": "rimraf dist",
    "prepublishOnly": "npm run clean && npm run typecheck && npm run test && npm run build",
    "release": "npm publish --access public"
  },
  "peerDependencies": {
    "chart.js": "^4.0.0",
    "echarts": "^5.0.0 || ^6.0.0",
    "gofish-graphics": "^0.0.22",
    "vega": "^5.0.0 || ^6.0.0",
    "vega-lite": "^5.0.0 || ^6.0.0"
  },
  "peerDependenciesMeta": {
    "vega": {
      "optional": true
    },
    "vega-lite": {
      "optional": true
    },
    "echarts": {
      "optional": true
    },
    "chart.js": {
      "optional": true
    },
    "gofish-graphics": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "eslint": "^9.15.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
