  "transform": [
    {
      "window": [
        {
          "op": "sum",
          "field": "Amount",
          "as": "__wf_sum_raw"
        }
      ]
    },
    {
      "calculate": "datum['Type'] === 'end' ? datum.__wf_sum_raw - datum['Amount'] : datum.__wf_sum_raw",
      "as": "__wf_sum"
    },
    {
      "calculate": "datum['Type'] === 'end' ? 0 : datum.__wf_sum - datum['Amount']",
      "as": "__wf_prev_sum"
    },
    {
      "calculate": "datum['Type'] !== 'delta' ? 'total' : datum['Amount'] >= 0 ? 'increase' : 'decrease'",
      "as": "__wf_color"
    }
  ],
