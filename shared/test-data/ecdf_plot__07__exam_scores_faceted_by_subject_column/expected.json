{
  "mark": {
    "type": "line",
    "interpolate": "step-after"
  },
  "transform": [
    {
      "window": [
        {
          "op": "count",
          "field": "Score",
          "as": "__ecdf_count"
        }
      ],
      "sort": [
        {
          "field": "Score",
          "order": "ascending"
        }
      ],
      "groupby": [
        "Subject"
      ],
      "frame": [
        null,
        0
      ]
    },
    {
      "joinaggregate": [
        {
          "op": "count",
          "field": "Score",
          "as": "__ecdf_total"
        }
      ],
      "groupby": [
        "Subject"
      ]
    },
    {
      "calculate": "datum['__ecdf_count'] / datum['__ecdf_total']",
      "as": "__ecdf"
    }
  ],
  "encoding": {
    "x": {
      "field": "Score",
      "type": "quantitative",
      "scale": {
        "nice": false,
        "zero": false
      },
      "title": "Score",
      "axis": {
        "format": ",.12~g"
      }
    },
    "y": {
      "field": "__ecdf",
      "type": "quantitative",
      "scale": {
        "domain": [
          0,
          1
        ]
      },
      "title": "Cumulative proportion",
      "axis": {
        "format": ",.12~g"
      }
    },
    "facet": {
      "field": "Subject",
      "type": "nominal",
      "sort": null,
      "columns": 3
    }
  },
  "config": {
    "view": {
      "continuousWidth": 233,
      "continuousHeight": 360
    },
    "axisX": {
