{
  "encoding": {
    "x": {
      "field": "Step",
      "type": "ordinal",
      "sort": null,
      "axis": {
        "labelAngle": -45
      }
    }
  },
  "transform": [
    {
      "window": [
        {
          "op": "sum",
          "field": "Amount",
          "as": "__wf_sum_raw"
        }
      ]
    },
    {
      "calculate": "datum['Type'] === 'end' ? datum.__wf_sum_raw - datum['Amount'] : datum.__wf_sum_raw",
      "as": "__wf_sum"
    },
    {
      "calculate": "datum['Type'] === 'end' ? 0 : datum.__wf_sum - datum['Amount']",
      "as": "__wf_prev_sum"
    },
    {
      "calculate": "datum['Type'] !== 'delta' ? 'total' : datum['Amount'] >= 0 ? 'increase' : 'decrease'",
      "as": "__wf_color"
    }
  ],
  "layer": [
    {
      "mark": {
        "type": "bar"
      },
      "encoding": {
        "y": {
          "field": "__wf_prev_sum",
          "type": "quantitative",
          "title": "Amount",
          "axis": {
            "format": ",.12~g"
          }
        },
        "y2": {
          "field": "__wf_sum"
        },
        "color": {
          "field": "__wf_color",
          "type": "nominal",
          "scale": {
            "domain": [
              "total",
              "increase",
              "decrease"
            ],
            "range": [
              "#f7e0b6",
              "#93c4aa",
              "#f78a64"
            ]
          },
          "legend": {
            "title": "Type"
          }
        }
      }
    }
  ],
  "config": {
    "view": {
      "continuousWidth": 400,
      "continuousHeight": 285
    },
    "axisX": {
      "labelLimit": 100,
      "labelFontSize": 10
    },
    "axisY": {
      "labelFontSize": 10
    },
    "facet": {
      "spacing": 29
    },
    "mark": {
      "tooltip": true
    }
  },
  "width": {
    "step": 27
  },
